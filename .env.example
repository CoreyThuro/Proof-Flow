# GitHub App credentials
# APP_ID is the numeric ID shown on the GitHub App settings page
APP_ID=

# Full PEM contents of the private key downloaded from GitHub App settings
# Include the -----BEGIN RSA PRIVATE KEY----- and -----END RSA PRIVATE KEY----- lines
PRIVATE_KEY=

# Secret you entered in the Webhook Secret field during App registration
WEBHOOK_SECRET=

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://localhost:5432/proofflow

# Optional: override the port Probot listens on (default: 3000)
# PORT=3000
